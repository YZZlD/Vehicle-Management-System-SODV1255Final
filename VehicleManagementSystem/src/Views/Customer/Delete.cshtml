@* @model VehicleManagementSystem.Models.Customer *@

<h1>Delete Customer</h1>

<p>Are you sure you want to delete this customer?</p>

<div>
    <strong>Name:</strong> @Model.FirstName @Model.LastName <br/>
    <strong>Phone Number:</strong> @Model.Phone <br/>
    <strong>Email:</strong> @Model.Email <br/>
</div>

<form asp-action="DeleteCustomer" method="post">
    <input type="hidden" name="id" value="@Model.CustomerId" />
    <button type="submit" >Confirm Delete</button>
    <a asp-action="Index">Cancel</a>
</form>
