@* @model VehicleManagementSystem.Model.Reservation *@

<h1>Choose Reservation Date Range</h1>

<form asp-action="SelectDate" method="post">
    <div >
        <label for="reservedDate">ReservedDate</label>
        <input name="reservedDate" type="date"/>
    </div>

    <div >
        <label for="dueDate">DueDate</label>
        <input name="dueDate" type="date"/>
    </div>

    <button type="submit">Save Changes</button>
    <a asp-action="Index">Cancel</a>
</form>
