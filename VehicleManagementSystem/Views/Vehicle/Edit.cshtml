@model VehicleManagementSystem.src.Models.VEHICLEMODEL

<h1>Edit Vehicle</h1>

<form asp-action="Edit" method="post">
    @* Optional ID binding for the edit method. Unnecessary with id route binding but doesn't hurt to add. *@
    <input type="hidden" asp-for="vehicleid" />

    <div class="form-group">
        <label asp-for="model"></label>
        <input asp-for="model"/>
    </div>

    <div class="form-group">
        <label asp-for="make"></label>
        <input asp-for="make"/>
    </div>

    <div class="form-group">
        <label asp-for="licenseplate"></label>
        <input asp-for="licenseplate"/>
    </div>

    <button type="submit">Save Changes</button>
    <a asp-action="Index">Cancel</a>
</form>
