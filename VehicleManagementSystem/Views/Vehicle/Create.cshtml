@model VehicleManagementSystem.src.Models.VEHICLEMODEL

<h1>Create New Vehicle</h1>

<form asp-action="Create" method="post">
    <div>
        <label asp-for="model">Model: </label>
        <input asp-name="model" />
    </div>

    <div>
        <label asp-for="make">Make: </label>
        <input asp-for="make" />
    </div>

    <div>
        <label asp-for="licenseplate">License Plate: </label>
        <input asp-for="licenseplate" />
    </div>

    <div>
        <label asp-for="price">Price Rate ($/day): </label>
        <input asp-for="price" />
    </div>

    <div>
        <label asp-for="imagelinkplaintext">Image URL: </label>
        <input asp-for="imagelinkplaintext" />
    </div>

    <button type="submit">Create Vehicle</button>
    <a asp-action="Index">Cancel</a>
</form>
