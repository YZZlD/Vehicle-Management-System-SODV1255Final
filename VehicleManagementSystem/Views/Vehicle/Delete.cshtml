@* @model VehicleManagementSystem.Models.Vehicle *@

<h1>Delete Vehicle</h1>

<p>Are you sure you want to delete this vehicle?</p>

<div>
    <strong>Vehicle:</strong> @Model.Make @Model.Model <br/>
    <strong>LicensePlate:</strong> @Model.LicensePlate <br/>
</div>

<form asp-action="DeleteVehicle" method="post">
    <input type="hidden" name="id" value="@Model.VehicleId" />
    <button type="submit" >Confirm Delete</button>
    <a asp-action="Index">Cancel</a>
</form>
