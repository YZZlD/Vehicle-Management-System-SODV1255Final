<div class="page-center">
    <div class="form-card">
        <h2>Create New Reservation</h2>

        <form asp-action="Create" method="post">
            <input type="hidden" name="reservedDate" value="@ViewBag.ReservedDate" />
            <input type="hidden" name="dueDate" value="@ViewBag.DueDate" />

            <div class="form-group">
                <label for="customerId">Customer</label>
                <select id="customerId" name="customerId" asp-items="@ViewBag.Customers">
                    <option value="">-- Select Customer --</option>
                </select>
            </div>

            <div class="form-group">
                <label for="vehicleId">Vehicle</label>
                <select id="vehicleId" name="vehicleId" asp-items="@ViewBag.Vehicles">
                    <option value="">-- Select Vehicle --</option>
                </select>
            </div>

            <button class="btn" type="submit">Create Reservation</button>
            <a asp-action="Index">Cancel</a>
        </form>
    </div>
</div>
