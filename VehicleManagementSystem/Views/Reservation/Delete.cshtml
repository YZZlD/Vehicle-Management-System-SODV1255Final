@model VehicleManagementSystem.src.Models.RESERVATIONMODEL

<div class="page-center">
    <div class="form-card">
        <h1>Delete Reservation</h1>

        <div class="detail-group">
            <div class=detail-row>
                <strong><p class="danger">Are you sure you want to delete this reservation?</p></strong> <br />
            </div>

            <div class="detail-row">
                <strong>Customer Name:</strong> @Model.user.fname @Model.user.lname
            </div>

            <div class="detail-row">
                <strong>Vehicle:</strong> @Model.vehicle.make @Model.vehicle.model
            </div>

            <div class="detail-row">
                <strong>Reserved Date:</strong> @Model.reservedate.ToString("MMM dd, yyyy")
            </div>

            <div class="detail-row">
                <strong>Due Date:</strong> @Model.duedate.ToString("MMM dd, yyyy")
            </div>

            <div class="detail-row">
                <strong>Total Price:</strong> @Model.price.ToString("C")
            </div>

        </div>

        <form asp-action="DeleteReservation" method="post">
            <input type="hidden" name="id" value="@Model.reservationid" />
            <div class="form-actions">
                <button class="btn" type="submit" >Confirm Delete</button>
                <a asp-action="Index">Cancel</a>
            </div>
        </form>
    </div>
</div>
