@model VehicleManagementSystem.src.Models.USERMODEL

<div class="page-center">
    <div class="form-card">
        <h2>Delete Customer</h2>

        <div class="detail-group">
            <div class=detail-row>
                <strong><p class="danger">Are you sure you want to delete this customer?</p></strong> <br />
            </div>
            <div class="detail-row">
                <strong>Name:</strong> @Model.fname @Model.lname <br/>
            </div>
            <div class="detail-row">
                <strong>Phone Number:</strong> @Model.phonenumber <br/>
            </div>
            <div class="detail-row">
                <strong>Email:</strong> @Model.email <br/>
            </div>
        </div>

        <form asp-action="DeleteCustomer" method="post">
            <input type="hidden" name="id" value="@Model.userid"/>
            <button class="btn" type="submit" >Confirm Delete</button>
            <a asp-action="Index">Cancel</a>
        </form>
    </div>
</div>
