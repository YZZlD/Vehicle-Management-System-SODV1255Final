<div class="page-center">
    <div class="form-card">
        <h2>Login</h2>

        <form asp-action="Login" method="post">
            <div class="form-group">
                <label for="username"></label>
                <input for="username" name="username" placeholder="Username"/>
            </div>

            <div class="form-group">
                <label for="password"></label>
                <input for="password" name="password" placeholder="Password"/>
            </div>

            @if(ViewBag.Error != null)
            {
                <p>@ViewBag.Error</p>
            }

            @if(TempData[key: "LogoutMessage"] != null)
            {
                <p>@TempData["LogoutMessage"]</p>
            }

            <button class="btn" type="submit">Login</button>
            <a asp-action="Register">Register</a>
        </form>
    </div>
</div>
